{
  "name": "agent-usage-stat",
  "version": "2.1.0",
  "description": "A local usage analytics portal for Claude Code and Codex",
  "license": "MIT",
  "author": "Yiliang Shao <github.com/yiliangs>",
  "contributors": [
    "Chris Hutchinson <github.com/chrishutchinson> (original author)"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yiliangs/agent-usage-stat.git"
  },
  "bugs": {
    "url": "https://github.com/yiliangs/agent-usage-stat/issues"
  },
  "homepage": "https://github.com/yiliangs/agent-usage-stat#readme",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "agent-usage-stat": "bin/agent-usage-stat.js"
  },
  "files": [
    "dist",
    "bin",
    "portal/scripts",
    "portal/Agent-Usage-Stat.bat",
    "portal/Agent-Usage-Stat.command",
    "Initialize-Agent-Usage-Stat.bat",
    "Initialize-Agent-Usage-Stat.command",
    "screenshot.png"
  ],
  "scripts": {
    "build": "node scripts/clean-dist.mjs && tsc && npm run build:portal",
    "build:portal": "npm --prefix portal run build",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build",
    "test": "npm run build && node --test test/*.test.mjs"
  },
  "keywords": [
    "claude-code",
    "codex",
    "openai",
    "usage",
    "analytics",
    "dashboard",
    "ai",
    "cli"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.2",
    "cross-spawn": "^7.0.6",
    "ora": "^9.1.0",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/cross-spawn": "^6.0.6",
    "@types/node": "^24.1.0",
    "@types/prompts": "^2.4.9",
    "typescript": "^5.9.3"
  }
}
